<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ccnu.user.mapper.UserMapper">

    <resultMap id="userMap" type="com.ccnu.user.domain.User">
        <id property="id" column="id"/>
        <result property="phone" column="phone"/>
        <result property="email" column="email"/>
        <result property="passwordHash" column="password_hash"/>
        <result property="nickname" column="nickname"/>
        <result property="avatar" column="avatar"/>
        <result property="bio" column="bio"/>
        <result property="zgId" column="zg_id"/>
        <result property="gender" column="gender"/>
        <result property="birthday" column="birthday"/>
        <result property="school" column="school"/>
        <result property="tagsJson" column="tags_json"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <insert id="insert" parameterType="com.ccnu.user.domain.User" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO users (phone, email, password_hash, nickname, avatar, bio, zg_id, gender, birthday, school, tags_json, created_at, updated_at)
        VALUES (#{phone}, #{email}, #{passwordHash}, #{nickname}, #{avatar}, #{bio}, #{zgId}, #{gender}, #{birthday}, #{school}, #{tagsJson}, NOW(), NOW())
    </insert>

    <update id="updatePassword">
        UPDATE users SET password_hash = #{passwordHash}, updated_at = NOW() WHERE id = #{id}
    </update>

    <select id="findById" resultMap="userMap">
        SELECT * FROM users WHERE id = #{id}
    </select>

    <select id="findByPhone" resultMap="userMap">
        SELECT * FROM users WHERE phone = #{phone} LIMIT 1
    </select>

    <select id="findByEmail" resultMap="userMap">
        SELECT * FROM users WHERE email = #{email} LIMIT 1
    </select>

    <select id="existsByPhone" resultType="boolean">
        SELECT COUNT(1) > 0 FROM users WHERE phone = #{phone}
    </select>

    <select id="existsByEmail" resultType="boolean">
        SELECT COUNT(1) > 0 FROM users WHERE email = #{email}
    </select>

    <select id="listByIds" resultMap="userMap">
        SELECT * FROM users WHERE id IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </select>

</mapper>